# Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASS=devmbilal
DB_NAME=shakeel_traders

# Session
SESSION_SECRET=change_this_to_a_long_random_string

# Server
PORT=3000

# Backup
BACKUP_DIR=./backups

# Google Drive Backup via Rclone (simplest — just browser login, no API keys)
# 1. Download rclone: https://rclone.org/downloads/ → Windows → extract rclone.exe
# 2. Run in CMD: rclone config → n → name: gdrive → Google Drive → blank → blank → 1 → n → n → y → browser opens → sign in → n → q
# 3. Create folder "Shakeel Traders Backups" in your Google Drive
# 4. Set RCLONE_ENABLED=true and restart server
RCLONE_ENABLED=true
RCLONE_EXE=C:\Users\Muhammad Bilal\Downloads\rclone-v1.73.4-windows-amd64\rclone-v1.73.4-windows-amd64\rclone.exe
RCLONE_REMOTE=gddrive
RCLONE_DRIVE_PATH=Shakeel Traders Backups
# Leave blank to use default: C:\Users\<you>\AppData\Roaming\rclone\rclone.conf
RCLONE_CONFIG=

# App
NODE_ENV=development
TZ=Asia/Karachi
