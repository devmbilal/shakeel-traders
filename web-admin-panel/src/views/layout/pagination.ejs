<% if (pagination && pagination.pages > 1) { %>
<nav class="mt-3">
  <ul class="pagination pagination-sm justify-content-center">
    <li class="page-item <%= pagination.page <= 1 ? 'disabled' : '' %>">
      <a class="page-link" href="?<%= queryString %>&page=1">«</a>
    </li>
    <li class="page-item <%= pagination.page <= 1 ? 'disabled' : '' %>">
      <a class="page-link" href="?<%= queryString %>&page=<%= pagination.page - 1 %>">‹</a>
    </li>
    <li class="page-item disabled">
      <a class="page-link">Page <%= pagination.page %> of <%= pagination.pages %> (<%= pagination.total %> records)</a>
    </li>
    <li class="page-item <%= pagination.page >= pagination.pages ? 'disabled' : '' %>">
      <a class="page-link" href="?<%= queryString %>&page=<%= pagination.page + 1 %>">›</a>
    </li>
    <li class="page-item <%= pagination.page >= pagination.pages ? 'disabled' : '' %>">
      <a class="page-link" href="?<%= queryString %>&page=<%= pagination.pages %>">»</a>
    </li>
  </ul>
</nav>
<% } %>
