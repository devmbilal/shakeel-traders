<div class="page-header">
  <div><h4>Recovery History</h4><div class="page-sub">Full history of all verified recovery transactions</div></div>
</div>
<div class="d-flex gap-2 mb-3">
  <a href="/cash-recovery/outstanding" class="btn btn-outline-secondary btn-sm">Outstanding Bills</a>
  <a href="/cash-recovery/settlement" class="btn btn-outline-secondary btn-sm">Bill Settlement (Delivery Man)</a>
  <a href="/cash-recovery/pending" class="btn btn-outline-secondary btn-sm">Pending Verifications</a>
  <a href="/cash-recovery/history" class="btn btn-dark-primary btn-sm">Recovery History</a>
</div>

<div class="card mb-3">
  <div class="card-body py-2 px-3">
    <form method="GET" action="/cash-recovery/history" class="d-flex gap-2 align-items-end flex-wrap">
      <div>
        <label class="form-label" style="font-size:0.72rem;">Date</label>
        <input type="date" name="date" class="form-control form-control-sm" value="<%= filters.date %>">
      </div>
      <div>
        <label class="form-label" style="font-size:0.72rem;">Order Booker</label>
        <select name="booker_id" class="form-select form-select-sm" data-searchable style="min-width:160px;">
          <option value="">All Bookers</option>
          <% bookers.forEach(b => { %><option value="<%= b.id %>" <%= filters.booker_id == b.id ? 'selected' : '' %>><%= b.full_name %></option><% }) %>
        </select>
      </div>
      <button type="submit" class="btn btn-primary btn-sm">Filter</button>
      <a href="/cash-recovery/history" class="btn btn-outline-secondary btn-sm">Clear</a>
    </form>
  </div>
</div>

<div class="card table-card">
  <% if (collections.length === 0) { %>
    <div style="text-align:center;padding:40px;color:var(--text-muted);">No recovery history found.</div>
  <% } else { %>
  <table class="table">
    <thead><tr><th>Bill #</th><th>Shop</th><th>Booker</th><th>Amount</th><th>Method</th><th>Verified At</th></tr></thead>
    <tbody>
      <% collections.forEach(c => { %>
      <tr>
        <td><code style="font-size:0.75rem;background:#F1F5F9;padding:2px 6px;border-radius:4px;"><%= c.bill_number %></code></td>
        <td style="font-weight:600;"><%= c.shop_name %></td>
        <td><%= c.booker_name %></td>
        <td style="font-weight:700;color:#10B981;">Rs <%= Number(c.amount_collected).toFixed(2) %></td>
        <td><span class="badge badge-blue"><%= c.payment_method.replace(/_/g,' ') %></span></td>
        <td style="font-size:0.78rem;"><%= new Date(c.verified_at).toLocaleString() %></td>
      </tr>
      <% }) %>
    </tbody>
  </table>
  <% } %>
</div>
