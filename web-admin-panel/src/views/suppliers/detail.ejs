<div class="page-header">
  <div>
    <h4><%= supplier.name %></h4>
    <div class="page-sub">Advance Balance: <strong style="color:<%= supplier.current_advance_balance > 0 ? '#10B981' : '#EF4444' %>;">Rs <%= Number(supplier.current_advance_balance).toFixed(2) %></strong></div>
  </div>
  <a href="/suppliers" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left me-1"></i> Back</a>
</div>

<div class="row g-3">
  <!-- Left: Ledger + Actions -->
  <div class="col-lg-8">
    <!-- Record Advance -->
    <div class="card mb-3">
      <div class="card-header d-flex align-items-center justify-content-between">
        <span>Record Advance Payment</span>
        <button class="btn btn-primary btn-sm" data-bs-toggle="collapse" data-bs-target="#advanceForm">
          <i class="bi bi-plus-lg me-1"></i> Add Advance
        </button>
      </div>
      <div class="collapse" id="advanceForm">
        <div class="card-body">
          <form method="POST" action="/suppliers/<%= supplier.id %>/advance">
            <div class="row g-3">
              <div class="col-md-3"><label class="form-label">Amount (Rs)</label><input type="number" name="amount" class="form-control" step="0.01" min="0.01" required></div>
              <div class="col-md-3"><label class="form-label">Date</label><input type="date" name="payment_date" class="form-control" value="<%= new Date().toISOString().slice(0,10) %>" required></div>
              <div class="col-md-3"><label class="form-label">Method</label><select name="payment_method" class="form-select" required><option value="cash">Cash</option><option value="bank_transfer">Bank Transfer</option><option value="cheque">Cheque</option><option value="other">Other</option></select></div>
              <div class="col-md-3"><label class="form-label">Note</label><input type="text" name="note" class="form-control" placeholder="Optional"></div>
            </div>
            <button type="submit" class="btn btn-primary btn-sm mt-3">Record Advance</button>
          </form>
        </div>
      </div>
    </div>

    <!-- Ledger History -->
    <div class="card">
      <div class="card-header">Ledger History</div>
      <div class="card-body p-0">
        <% if (!ledger.length) { %>
          <div style="text-align:center;padding:32px;color:var(--text-muted);">No transactions yet.</div>
        <% } else { %>
        <table class="table mb-0">
          <thead><tr><th>Date</th><th>Type</th><th>Amount</th><th>Note</th></tr></thead>
          <tbody>
            <% ledger.forEach(l => { %>
            <tr>
              <td style="font-size:0.78rem;"><%= l.date %></td>
              <td>
                <span class="badge <%= l.type === 'advance' ? 'badge-approved' : l.type === 'receipt' ? 'badge-open' : 'badge-blue' %>">
                  <%= l.type %>
                </span>
              </td>
              <td style="font-weight:700;color:<%= l.type === 'advance' ? '#10B981' : '#EF4444' %>;">
                <%= l.type === 'advance' ? '+' : '-' %> Rs <%= Number(l.amount).toFixed(2) %>
              </td>
              <td style="font-size:0.78rem;color:var(--text-secondary);"><%= l.note || '—' %></td>
            </tr>
            <% }) %>
          </tbody>
        </table>
        <% } %>
      </div>
    </div>
  </div>

  <!-- Right: Claims -->
  <div class="col-lg-4">
    <div class="card">
      <div class="card-header d-flex align-items-center justify-content-between">
        <span>Claims</span>
        <button class="btn btn-outline-secondary btn-sm" data-bs-toggle="modal" data-bs-target="#claimModal">
          <i class="bi bi-plus-lg me-1"></i> New Claim
        </button>
      </div>
      <div class="card-body p-0">
        <% if (!claims.length) { %>
          <div style="text-align:center;padding:24px;color:var(--text-muted);font-size:0.82rem;">No claims.</div>
        <% } else { %>
        <% claims.forEach(c => { %>
        <div style="padding:12px 16px;border-bottom:1px solid var(--border);">
          <div style="display:flex;justify-content:space-between;align-items:flex-start;">
            <div>
              <div style="font-weight:600;font-size:0.82rem;"><%= c.products || 'Products' %></div>
              <div style="font-size:0.72rem;color:var(--text-muted);">Rs <%= Number(c.claim_value).toFixed(2) %> | <%= c.claim_date %></div>
              <div style="font-size:0.72rem;color:var(--text-secondary);margin-top:2px;"><%= c.reason %></div>
            </div>
            <div style="text-align:right;">
              <span class="badge <%= c.status === 'cleared' ? 'badge-approved' : 'badge-pending' %>"><%= c.status %></span>
              <% if (c.status === 'pending') { %>
              <form method="POST" action="/suppliers/<%= supplier.id %>/claims/<%= c.id %>/clear" style="margin-top:4px;">
                <button type="submit" class="btn btn-assign btn-sm" style="font-size:0.7rem;padding:2px 8px;" onclick="return confirm('Mark claim as cleared?')">Clear</button>
              </form>
              <% } %>
            </div>
          </div>
        </div>
        <% }) %>
        <% } %>
      </div>
    </div>
  </div>
</div>

<!-- New Claim Modal -->
<div class="modal fade" id="claimModal" tabindex="-1">
  <div class="modal-dialog modal-lg">
    <div class="modal-content">
      <div class="modal-header"><h6 class="modal-title">New Claim</h6><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
      <form method="POST" action="/suppliers/<%= supplier.id %>/claims">
        <div class="modal-body">
          <div class="alert alert-warning py-2" style="font-size:0.78rem;"><i class="bi bi-exclamation-triangle me-1"></i>Claimed products are <strong>NOT added to warehouse stock</strong>.</div>
          <div class="row g-3 mb-3">
            <div class="col-md-4"><label class="form-label">Claim Date</label><input type="date" name="claim_date" class="form-control" value="<%= new Date().toISOString().slice(0,10) %>" required></div>
            <div class="col-md-4"><label class="form-label">Claim Value (Rs)</label><input type="number" name="claim_value" class="form-control" step="0.01" min="0.01" required></div>
            <div class="col-12"><label class="form-label">Reason</label><textarea name="reason" class="form-control" rows="2" required></textarea></div>
          </div>
          <div id="claimItems">
            <div class="row g-2 mb-2 claim-item">
              <div class="col-md-5"><select name="product_id" class="form-select" data-searchable><option value="">— Product (optional) —</option><% products.forEach(p => { %><option value="<%= p.id %>"><%= p.sku_code %> — <%= p.name %></option><% }) %></select></div>
              <div class="col-md-3"><input type="number" name="cartons" class="form-control" placeholder="Cartons" min="0" value="0"></div>
              <div class="col-md-3"><input type="number" name="loose_units" class="form-control" placeholder="Loose" min="0" value="0"></div>
            </div>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-outline-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
          <button type="submit" class="btn btn-primary btn-sm">Submit Claim</button>
        </div>
      </form>
    </div>
  </div>
</div>
