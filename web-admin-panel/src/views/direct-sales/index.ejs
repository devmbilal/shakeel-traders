<div class="page-header">
  <div><h4>Direct Shop Sales</h4><div class="page-sub">All direct sale bills</div></div>
  <a href="/direct-sales/new" class="btn btn-primary btn-sm"><i class="bi bi-plus-lg me-1"></i> New Bill</a>
</div>

<div class="card mb-3">
  <div class="card-body py-2 px-3">
    <form method="GET" action="/direct-sales" class="d-flex gap-2 align-items-end flex-wrap">
      <div>
        <label class="form-label" style="font-size:0.72rem;">Date</label>
        <input type="date" name="date" class="form-control form-control-sm" value="<%= filters.date %>">
      </div>
      <div>
        <label class="form-label" style="font-size:0.72rem;">Shop</label>
        <select name="shop_id" class="form-select form-select-sm" data-searchable style="min-width:160px;">
          <option value="">All Shops</option>
          <% shops.forEach(s => { %><option value="<%= s.id %>" <%= filters.shop_id == s.id ? 'selected' : '' %>><%= s.name %></option><% }) %>
        </select>
      </div>
      <button type="submit" class="btn btn-primary btn-sm">Filter</button>
      <a href="/direct-sales" class="btn btn-outline-secondary btn-sm">Clear</a>
    </form>
  </div>
</div>

<div class="card table-card">
  <% if (bills.length === 0) { %>
    <div style="text-align:center;padding:48px;color:var(--text-muted);">No direct sale bills found.</div>
  <% } else { %>
  <table class="table">
    <thead><tr><th>Bill #</th><th>Shop</th><th>Date</th><th>Net Amount</th><th>Outstanding</th><th>Status</th><th>Actions</th></tr></thead>
    <tbody>
      <% bills.forEach(b => { %>
      <tr>
        <td><code style="font-size:0.75rem;background:#F1F5F9;padding:2px 6px;border-radius:4px;"><%= b.bill_number %></code></td>
        <td style="font-weight:600;"><%= b.shop_name %></td>
        <td style="font-size:0.78rem;"><%= b.bill_date %></td>
        <td style="font-weight:700;">Rs <%= Number(b.net_amount).toFixed(2) %></td>
        <td style="color:<%= b.outstanding_amount > 0 ? '#EF4444' : '#10B981' %>;font-weight:600;">Rs <%= Number(b.outstanding_amount).toFixed(2) %></td>
        <td><span class="badge badge-<%= b.status === 'cleared' ? 'cleared' : b.status === 'partially_paid' ? 'partially' : 'open' %>"><%= b.status.replace(/_/g,' ') %></span></td>
        <td>
          <a href="/direct-sales/<%= b.id %>/print" target="_blank" class="btn btn-icon btn-outline-secondary" title="Print">
            <i class="bi bi-printer"></i>
          </a>
        </td>
      </tr>
      <% }) %>
    </tbody>
  </table>
  <% } %>
</div>
