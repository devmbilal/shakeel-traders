<div class="mb-3 d-flex justify-content-between align-items-center flex-wrap gap-2">
  <div class="d-flex align-items-center gap-2">
    <a href="/shops/<%= shop.id %>" class="btn btn-sm btn-outline-secondary">
      <i class="bi bi-arrow-left me-1"></i> Back to Shop
    </a>
    <a href="/shops" class="btn btn-sm btn-outline-secondary">
      <i class="bi bi-shop me-1"></i> All Shops
    </a>
  </div>
  <div class="d-flex align-items-center gap-2">
    <a href="/shops/<%= shop.id %>/ledger/export" class="btn btn-sm btn-outline-success">
      <i class="bi bi-file-earmark-excel me-1"></i> Export Excel
    </a>
    <button class="btn btn-sm btn-primary" data-bs-toggle="modal" data-bs-target="#advanceModal">
      <i class="bi bi-plus-circle me-1"></i> Add Advance
    </button>
  </div>
</div>

<!-- Shop Header -->
<div class="card mb-4">
  <div class="card-body">
    <div class="row align-items-center">
      <div class="col-md-6">
        <h5 class="fw-bold mb-1"><i class="bi bi-shop text-primary me-2"></i><%= shop.name %></h5>
        <div class="text-muted small">
          <% if (shop.owner_name) { %><span class="me-3"><i class="bi bi-person me-1"></i><%= shop.owner_name %></span><% } %>
          <% if (shop.route_name) { %><span class="me-3"><i class="bi bi-map me-1"></i><%= shop.route_name %></span><% } %>
          <% if (shop.phone) { %><span><i class="bi bi-telephone me-1"></i><%= shop.phone %></span><% } %>
        </div>
      </div>
      <div class="col-md-6 text-md-end mt-3 mt-md-0">
        <div class="small text-muted mb-1">Current Balance</div>
        <div class="fs-4 fw-bold <%= balance < 0 ? 'text-success' : balance > 0 ? 'text-danger' : 'text-muted' %>">
          Rs <%= Math.abs(balance).toLocaleString('en-PK', {minimumFractionDigits: 2}) %>
          <% if (balance < 0) { %><span class="badge bg-success-subtle text-success fs-6 ms-1">Credit</span>
          <% } else if (balance > 0) { %><span class="badge bg-danger-subtle text-danger fs-6 ms-1">Outstanding</span>
          <% } else { %><span class="badge bg-secondary-subtle text-secondary fs-6 ms-1">Clear</span><% } %>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Ledger Table -->
<div class="card">
  <div class="card-header d-flex justify-content-between align-items-center">
    <span><i class="bi bi-journal-text me-2"></i>Ledger Entries</span>
    <span class="badge bg-secondary"><%= entries.length %> entries</span>
  </div>
  <div class="card-body p-0">
    <% if (entries.length === 0) { %>
      <div class="text-center py-5 text-muted">
        <i class="bi bi-journal-x fs-1 d-block mb-2"></i>
        No ledger entries yet.
      </div>
    <% } else { %>
      <div class="table-responsive">
        <table class="table table-hover table-sm mb-0">
          <thead class="table-light">
            <tr>
              <th>Date</th>
              <th>Type</th>
              <th>Note</th>
              <th class="text-end">Debit (Dr)</th>
              <th class="text-end">Credit (Cr)</th>
              <th class="text-end">Balance</th>
            </tr>
          </thead>
          <tbody>
            <% entries.forEach(e => { %>
              <tr>
                <td class="text-nowrap small"><%= e.entry_date ? new Date(e.entry_date).toLocaleDateString('en-PK') : '' %></td>
                <td>
                  <% const typeMap = {
                    bill: { label: 'Bill', cls: 'bg-primary-subtle text-primary' },
                    payment_delivery_man: { label: 'Payment (DM)', cls: 'bg-success-subtle text-success' },
                    recovery: { label: 'Recovery', cls: 'bg-info-subtle text-info' },
                    advance_payment: { label: 'Advance', cls: 'bg-warning-subtle text-warning' },
                    advance_adjustment: { label: 'Adv. Adjust', cls: 'bg-secondary-subtle text-secondary' },
                    claim_credit: { label: 'Claim Credit', cls: 'bg-teal-subtle text-teal' },
                  };
                  const t = typeMap[e.entry_type] || { label: e.entry_type, cls: 'bg-secondary-subtle text-secondary' };
                  %>
                  <span class="badge <%= t.cls %> small"><%= t.label %></span>
                </td>
                <td class="small text-muted"><%= e.note || '—' %></td>
                <td class="text-end small">
                  <% if (parseFloat(e.debit) > 0) { %>
                    <span class="text-danger fw-semibold">Rs <%= parseFloat(e.debit).toLocaleString('en-PK', {minimumFractionDigits: 2}) %></span>
                  <% } else { %>—<% } %>
                </td>
                <td class="text-end small">
                  <% if (parseFloat(e.credit) > 0) { %>
                    <span class="text-success fw-semibold">Rs <%= parseFloat(e.credit).toLocaleString('en-PK', {minimumFractionDigits: 2}) %></span>
                  <% } else { %>—<% } %>
                </td>
                <td class="text-end small fw-semibold <%= parseFloat(e.balance_after) < 0 ? 'text-success' : parseFloat(e.balance_after) > 0 ? 'text-danger' : 'text-muted' %>">
                  Rs <%= parseFloat(e.balance_after).toLocaleString('en-PK', {minimumFractionDigits: 2}) %>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>
  </div>
</div>

<!-- Add Advance Modal -->
<div class="modal fade" id="advanceModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">
      <form method="POST" action="/shops/<%= shop.id %>/advance">
        <div class="modal-header">
          <h5 class="modal-title"><i class="bi bi-cash-coin me-2"></i>Record Shop Advance</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
        </div>
        <div class="modal-body">
          <div class="mb-3">
            <label class="form-label fw-semibold">Amount (Rs) <span class="text-danger">*</span></label>
            <input type="number" name="amount" class="form-control" step="0.01" min="0.01" required placeholder="0.00">
          </div>
          <div class="mb-3">
            <label class="form-label fw-semibold">Date <span class="text-danger">*</span></label>
            <input type="date" name="advance_date" class="form-control" required
                   value="<%= new Date().toISOString().split('T')[0] %>">
          </div>
          <div class="mb-3">
            <label class="form-label fw-semibold">Payment Method <span class="text-danger">*</span></label>
            <select name="payment_method" class="form-select" required>
              <option value="cash">Cash</option>
              <option value="bank_transfer">Bank Transfer</option>
              <option value="cheque">Cheque</option>
              <option value="other">Other</option>
            </select>
          </div>
          <div class="mb-3">
            <label class="form-label fw-semibold">Note (Optional)</label>
            <textarea name="note" class="form-control" rows="2" placeholder="Optional note..."></textarea>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
          <button type="submit" class="btn btn-primary">
            <i class="bi bi-check-circle me-1"></i> Save Advance
          </button>
        </div>
      </form>
    </div>
  </div>
</div>

<% if (pagination && pagination.pages > 1) { %>
<nav class="mt-3">
  <ul class="pagination pagination-sm justify-content-center">
    <li class="page-item <%= pagination.page <= 1 ? 'disabled' : '' %>">
      <a class="page-link" href="?page=<%= pagination.page - 1 %>">Previous</a>
    </li>
    <% for(let p = Math.max(1, pagination.page-2); p <= Math.min(pagination.pages, pagination.page+2); p++) { %>
    <li class="page-item <%= p === pagination.page ? 'active' : '' %>">
      <a class="page-link" href="?page=<%= p %>"><%= p %></a>
    </li>
    <% } %>
    <li class="page-item <%= pagination.page >= pagination.pages ? 'disabled' : '' %>">
      <a class="page-link" href="?page=<%= pagination.page + 1 %>">Next</a>
    </li>
  </ul>
  <div class="text-center small text-muted">Showing page <%= pagination.page %> of <%= pagination.pages %> (<%= pagination.total %> entries)</div>
</nav>
<% } %>
