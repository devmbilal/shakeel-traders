<div class="page-header">
  <div><h4>Converted Bills</h4><div class="page-sub">Bills generated from order booker orders</div></div>
  <div class="d-flex gap-2">
    <a href="/orders" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left me-1"></i> Pending Orders</a>
    <a href="/orders/bills/print-open" class="btn btn-outline-primary btn-sm" target="_blank">
      <i class="bi bi-printer me-1"></i> Print All Open Bills
    </a>
  </div>
</div>

<!-- Date Filter -->
<div class="card mb-3">
  <div class="card-body py-2 px-3">
    <form method="GET" action="/orders/converted" class="d-flex gap-2 flex-wrap align-items-end">
      <div>
        <label class="form-label" style="font-size:0.72rem;">Bill Date</label>
        <input type="date" name="date" class="form-control form-control-sm" value="<%= filters.date %>">
      </div>
      <button type="submit" class="btn btn-primary btn-sm">Filter</button>
      <a href="/orders/converted" class="btn btn-outline-secondary btn-sm">Clear</a>
    </form>
  </div>
</div>

<% if (pagination && pagination.total > 0) { %>
  <p class="text-muted small mb-2"><%= pagination.total %> records</p>
<% } %>

<div class="card table-card">
  <% if (bills.length === 0) { %>
    <div style="text-align:center;padding:48px;color:var(--text-muted);">No converted bills found.</div>
  <% } else { %>
  <table class="table">
    <thead><tr><th>Bill #</th><th>Shop</th><th>Date</th><th>Gross</th><th>Advance</th><th>Net</th><th>Outstanding</th><th>Status</th><th>Actions</th></tr></thead>
    <tbody>
      <% bills.forEach(b => { %>
      <tr>
        <td><code style="font-size:0.75rem;background:#F1F5F9;padding:2px 6px;border-radius:4px;"><%= b.bill_number %></code></td>
        <td style="font-weight:600;"><%= b.shop_name %></td>
        <td style="font-size:0.78rem;"><%= b.bill_date %></td>
        <td>Rs <%= Number(b.gross_amount).toFixed(2) %></td>
        <td style="color:#10B981;">Rs <%= Number(b.advance_deducted).toFixed(2) %></td>
        <td style="font-weight:700;">Rs <%= Number(b.net_amount).toFixed(2) %></td>
        <td style="color:<%= b.outstanding_amount > 0 ? '#EF4444' : '#10B981' %>;font-weight:600;">
          Rs <%= Number(b.outstanding_amount).toFixed(2) %>
        </td>
        <td><span class="badge badge-<%= b.status === 'cleared' ? 'cleared' : b.status === 'partially_paid' ? 'partially' : 'open' %>"><%= b.status.replace(/_/g,' ') %></span></td>
        <td>
          <a href="/orders/bills/<%= b.id %>/print" target="_blank" class="btn btn-icon btn-outline-secondary" title="Print">
            <i class="bi bi-printer"></i>
          </a>
        </td>
      </tr>
      <% }) %>
    </tbody>
  </table>
  <% } %>
</div>

<%- include('../layout/pagination', {pagination, queryString}) %>
