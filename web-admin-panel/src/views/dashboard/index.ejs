    <!-- Route Breakdown -->
    <div class="col-lg-6">
      <div class="db-section">
        <div class="db-section-header">
          <span class="db-section-title">Top Routes by Sales</span>
          <a href="/routes" style="font-size:0.72rem;font-weight:700;color:var(--secondary);text-decoration:none;"></a>
        </div>
        <div class="db-section-body" id="routeBreakdownGraph">
          <div style="font-size:0.8rem;color:var(--text-muted);text-align:center;padding:24px 0;">Loading…</div>
        </div>
      </div>
    </div>

  </div>

</div><!-- /#dashboardContent -->

<script>
(function () {
  'use strict';

  var currentView = 'daily';

  /* ── Helpers ── */
  function fmt(amount) {
    var n = parseFloat(amount || 0);
    if (n >= 10000000) return 'Rs ' + (n / 10000000).toFixed(1) + 'Cr';
    if (n >= 100000)   return 'Rs ' + (n / 100000).toFixed(1) + 'L';
    if (n >= 1000)     return 'Rs ' + (n / 1000).toFixed(0) + 'K';
    return 'Rs ' + n.toLocaleString('en-IN', { maximumFractionDigits: 0 });
  }

  function set(id, val) {
    var el = document.getElementById(id);
    if (el) el.textContent = val;
  }

  /* ── Render ── */
  function render(data) {
    /* Quick stats */
    var s = data.stats || {};
    set('qs-shops',    s.total_shops    || 0);
    set('qs-products', s.total_products || 0);
    set('qs-bookers',  s.active_bookers || 0);
    set('qs-routes',   s.total_routes   || 0);

    /* Server connection info */
    var srv = data.server || {};
    set('serverIP',   srv.ip   || '—');
    set('serverPort', String(srv.port || '—'));

    /* Subtitle */
    set('dashSubtitle', 'Real-time overview — ' + (data.dateLabel || 'Today'));

    /* Financial hero */
    var f = data.financials || {};
    set('totalOutstanding',    fmt(f.totalOutstanding));
    set('outstandingBillCount', (f.outstandingBillCount || 0) + ' open bills');
    set('supplierAdvance',     fmt(f.supplierAdvance));
    set('supplierCount',       (f.supplierCount || 0) + ' suppliers');
    set('stockValue',          fmt(f.stockValue));
    set('stockUnits',          (f.totalCartons || 0).toLocaleString() + ' ctn + ' + (f.totalLoose || 0).toLocaleString() + ' loose');

    /* Cash */
    var c = data.cash || {};
    set('cashCollectedTotal', fmt(c.total));
    set('cashSalesmanSale',   fmt(c.salesman_sale));
    set('cashRecovery',       fmt(c.recovery));
    set('cashDeliveryMan',    fmt(c.delivery_man_collection));

    /* Orders */
    var bp = data.bookerPerformance || [];
    var totalOrders = bp.reduce(function (sum, b) { return sum + parseInt(b.orders_booked || 0); }, 0);
    set('totalOrdersBooked', totalOrders);
    renderTopBookers(bp);

    /* Alerts */
    var al = data.alerts || {};
    var totalAlerts = (al.lowStockCount || 0) + (al.pendingOrders || 0) + (al.pendingIssuances || 0) + (al.pendingReturns || 0) + (al.unsyncedBookers || []).length;
    set('totalAlertsCount',      totalAlerts);
    set('lowStockCount',         al.lowStockCount || 0);
    set('pendingOrdersCount',    al.pendingOrders || 0);
    set('pendingIssuancesCount', al.pendingIssuances || 0);
    set('pendingReturnsCount',   al.pendingReturns || 0);
    set('unsyncedCount',         (al.unsyncedBookers || []).length);

    /* Sales by channel */
    var sl = data.sales || {};
    set('salesOrderBooker',      fmt((sl.order_booker || {}).sales));
    set('salesOrderBookerCount', ((sl.order_booker || {}).count || 0) + ' bills');
    set('salesSalesman',         fmt((sl.salesman || {}).sales));
    set('salesSalesmanCount',    'Stock-based sales');
    set('salesDirectShop',       fmt((sl.direct_shop || {}).sales));
    set('salesDirectShopCount',  ((sl.direct_shop || {}).count || 0) + ' bills');

    /* Charts */
    renderBarChart('salesmanSalesGraph',  data.salesmanBreakdown || [], 'salesman_name', 'total_sales',  '#10B981', '/direct-sales');
    renderBarChart('routeBreakdownGraph', data.routeBreakdown    || [], 'route_name',    'total_sales',  '#3B82F6', '/routes');
  }

  function renderTopBookers(data) {
    var el = document.getElementById('topBookersList');
    if (!el) return;
    if (!data || !data.length) {
      el.innerHTML = '<div class="db-orders-row"><span style="font-size:0.75rem;color:rgba(255,255,255,0.45);">No data</span></div>';
      return;
    }
    el.innerHTML = data.slice(0, 3).map(function (b, i) {
      return '<div class="db-orders-row">' +
        '<div class="d-flex align-items-center gap-2">' +
        '<div style="width:22px;height:22px;border-radius:5px;background:rgba(255,255,255,0.2);display:flex;align-items:center;justify-content:center;font-size:0.65rem;font-weight:800;color:#fff;">' + (i + 1) + '</div>' +
        '<span style="font-size:0.78rem;font-weight:600;color:#fff;">' + b.full_name + '</span>' +
        '</div>' +
        '<span style="font-size:0.75rem;font-weight:700;color:rgba(255,255,255,0.85);">' + b.orders_booked + ' orders</span>' +
        '</div>';
    }).join('');
  }

  function renderBarChart(containerId, data, nameKey, valueKey, color, link) {
    var el = document.getElementById(containerId);
    if (!el) return;
    if (!data || !data.length) {
      el.innerHTML = '<div style="font-size:0.8rem;color:var(--text-muted);text-align:center;padding:24px 0;">No data for this period</div>';
      return;
    }
    var max = Math.max.apply(Math, data.map(function (r) { return parseFloat(r[valueKey] || 0); }));
    el.innerHTML = data.slice(0, 6).map(function (r) {
      var val = parseFloat(r[valueKey] || 0);
      var pct = max > 0 ? Math.round(val / max * 100) : 0;
      // For salesman breakdown show cartons+loose instead of bill count
      var sub = '';
      if (r.total_sold_cartons !== undefined) {
        sub = '<span style="font-size:0.68rem;color:var(--text-muted);">' +
              (r.total_sold_cartons || 0) + ' ctn + ' + (r.total_sold_loose || 0) + ' loose sold</span>';
      }
      return '<div class="db-bar-row">' +
        '<div class="db-bar-meta">' +
        '<div><span class="db-bar-name">' + (r[nameKey] || '—') + '</span>' +
        (sub ? '<br>' + sub : '') + '</div>' +
        '<span class="db-bar-val">' + fmt(val) + '</span>' +
        '</div>' +
        '<div class="db-bar-track">' +
        '<div class="db-bar-fill" style="width:' + pct + '%;background:' + color + ';"></div>' +
        '</div>' +
        '</div>';
    }).join('');
  }

  /* ── Fetch ── */
  function load() {
    document.getElementById('errorState').classList.add('d-none');
    fetch('/dashboard/data?view=' + currentView)
      .then(function (r) { if (!r.ok) throw new Error('HTTP ' + r.status); return r.json(); })
      .then(function (data) { render(data); })
      .catch(function (err) {
        document.getElementById('errorState').classList.remove('d-none');
        set('errorMessage', err.message);
      });
  }

  /* ── Copy to clipboard ── */
  window.copyToClipboard = function (id) {
    var el = document.getElementById(id);
    if (!el) return;
    navigator.clipboard.writeText(el.textContent.trim()).then(function () {
      var orig = el.style.background;
      el.style.background = 'rgba(52,211,153,0.25)';
      setTimeout(function () { el.style.background = orig; }, 800);
    });
  };

  window.switchView = function (v) {
    currentView = v;
    ['daily','monthly','yearly'].forEach(function (x) {
      var btn = document.getElementById('btn' + x.charAt(0).toUpperCase() + x.slice(1));
      if (btn) btn.className = 'db-period-btn' + (x === v ? ' active' : '');
    });
    load();
  };

  window.refreshDashboard = load;

  /* ── Init ── */
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', load);
  } else {
    load();
  }
  setInterval(load, 60000);

})();
</script>
