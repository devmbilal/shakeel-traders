      </div>
    </div>

  </div>

  <!-- ROW 3: Sales by Channel KPIs -->
  <div class="row g-3 mb-3">
    <div class="col-md-4">
      <div class="db-kpi">
        <div class="d-flex align-items-center justify-content-between mb-3">
          <div class="db-kpi-label">Order Booker Sales</div>
          <div class="db-kpi-icon" style="background:#EFF6FF;">
            <i class="bi bi-person-badge" style="color:#3B82F6;"></i>
          </div>
        </div>
        <div class="db-kpi-value" id="salesOrderBooker">Rs —</div>
        <div class="db-kpi-sub" id="salesOrderBookerCount">— bills</div>
      </div>
    </div>
    <div class="col-md-4">
      <div class="db-kpi">
        <div class="d-flex align-items-center justify-content-between mb-3">
          <div class="db-kpi-label">Salesman Sales</div>
          <div class="db-kpi-icon" style="background:#F0FDF4;">
            <i class="bi bi-truck" style="color:#10B981;"></i>
          </div>
        </div>
        <div class="db-kpi-value" id="salesSalesman">Rs —</div>
        <div class="db-kpi-sub" id="salesSalesmanCount">— bills</div>
      </div>
    </div>
    <div class="col-md-4">
      <div class="db-kpi">
        <div class="d-flex align-items-center justify-content-between mb-3">
          <div class="db-kpi-label">Direct Shop Sales</div>
          <div class="db-kpi-icon" style="background:#FFF7ED;">
            <i class="bi bi-shop" style="color:#F59E0B;"></i>
          </div>
        </div>
        <div class="db-kpi-value" id="salesDirectShop">Rs —</div>
        <div class="db-kpi-sub" id="salesDirectShopCount">— bills</div>
      </div>
    </div>
  </div>

  <!-- ROW 4: Salesman Graph + Route Breakdown -->
  <div class="row g-3">

    <!-- Salesman Sales Bar Chart -->
    <div class="col-lg-6">
      <div class="db-section">
        <div class="db-section-header">
          <span class="db-section-title">Salesman Sales Breakdown</span>
          <a href="/direct-sales" style="font-size:0.72rem;font-weight:700;color:var(--secondary);text-decoration:none;"></a>
