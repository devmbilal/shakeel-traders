<div class="page-header">
  <div><h4>Monthly Sales Report</h4><div class="page-sub">Sales breakdown by channel for a month</div></div>
  <a href="/reports" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left me-1"></i> Reports</a>
</div>

<div class="card mb-4">
  <div class="card-body">
    <form method="GET" action="/reports/monthly-sales" class="row g-3 align-items-end">
      <div class="col-md-3">
        <label class="form-label fw-semibold">Month</label>
        <select name="month" class="form-select">
          <% for(let m=1;m<=12;m++) { %>
          <option value="<%= m %>" <%= m == reportMonth ? 'selected' : '' %>><%= new Date(2000,m-1,1).toLocaleString('default',{month:'long'}) %></option>
          <% } %>
        </select>
      </div>
      <div class="col-md-3">
        <label class="form-label fw-semibold">Year</label>
        <input type="number" name="year" class="form-control" value="<%= reportYear %>" min="2020" max="2030">
      </div>
      <div class="col-md-4">
        <button type="submit" class="btn btn-primary me-2"><i class="bi bi-search me-1"></i> Generate</button>
        <a href="/reports/monthly-sales?month=<%= reportMonth %>&year=<%= reportYear %>&export=excel" class="btn btn-outline-success"><i class="bi bi-file-earmark-excel me-1"></i> Export</a>
      </div>
    </form>
  </div>
</div>

<div class="row g-4 mb-4">
  <%
    const channels = [
      { key: 'order_booker', label: 'Order Booker Sales', color: 'primary' },
      { key: 'salesman',     label: 'Salesman Sales',     color: 'success' },
      { key: 'direct_shop',  label: 'Direct Shop Sales',  color: 'warning' }
    ];
  %>
  <% channels.forEach(ch => { const d = data[ch.key] || {}; %>
  <div class="col-md-4">
    <div class="card h-100">
      <div class="card-header"><i class="bi bi-shop text-<%= ch.color %> me-2"></i><%= ch.label %></div>
      <div class="card-body">
        <% if (ch.key === 'salesman') { %>
        <div class="row g-2 text-center">
          <div class="col-12"><div class="small text-muted">Sale Value (Stock-Based)</div><div class="fw-bold fs-4 text-success">Rs <%= Number(d.sale_value || 0).toLocaleString() %></div></div>
          <div class="col-12"><div class="small text-muted">Approved Returns</div><div class="fw-semibold"><%= d.returns_count || 0 %> returns</div></div>
          <div class="col-12"><div class="small text-muted fst-italic">No bills — sales recorded via stock return</div></div>
        </div>
        <% } else { %>
        <div class="row g-2 text-center">
          <div class="col-6"><div class="small text-muted">Bills</div><div class="fw-bold fs-5"><%= d.bill_count || 0 %></div></div>
          <div class="col-6"><div class="small text-muted">Net Amount</div><div class="fw-bold fs-5 text-<%= ch.color %>">Rs <%= Number(d.net_amount || 0).toLocaleString() %></div></div>
          <div class="col-6"><div class="small text-muted">Gross</div><div class="fw-semibold">Rs <%= Number(d.gross_amount || 0).toLocaleString() %></div></div>
          <div class="col-6"><div class="small text-muted">Outstanding</div><div class="fw-semibold text-danger">Rs <%= Number(d.outstanding_amount || 0).toLocaleString() %></div></div>
        </div>
        <% } %>
      </div>
    </div>
  </div>
  <% }) %>
</div>

<div class="card">
  <div class="card-header">Total for <%= reportMonth %>/<%= reportYear %></div>
  <div class="card-body text-center">
    <div class="fw-bold fs-3 text-primary">Rs <%= Number(data.total || 0).toLocaleString() %></div>
    <div class="small text-muted">Total Net Sales (Order Booker + Salesman + Direct Shop)</div>
  </div>
</div>

<% 
const queryString = new URLSearchParams({ month: reportMonth, year: reportYear }).toString();
%>
<%- include('../layout/pagination', { pagination, queryString }) %>
