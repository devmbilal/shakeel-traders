<div class="page-header">
  <div><h4>Stock Movement Report</h4></div>
  <div class="d-flex gap-2">
    <a href="/reports/stock-movement?startDate=<%= filters.startDate||'' %>&endDate=<%= filters.endDate||'' %>&export=excel" class="btn btn-outline-success btn-sm"><i class="bi bi-file-earmark-excel me-1"></i> Export</a>
    <a href="/reports" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left me-1"></i> Reports</a>
  </div>
</div>

<div class="card mb-4">
  <div class="card-body">
    <form method="GET" action="/reports/stock-movement" class="row g-3 align-items-end">
      <div class="col-md-3"><label class="form-label fw-semibold">From</label><input type="date" name="startDate" class="form-control" value="<%= filters.startDate||'' %>"></div>
      <div class="col-md-3"><label class="form-label fw-semibold">To</label><input type="date" name="endDate" class="form-control" value="<%= filters.endDate||'' %>"></div>
      <div class="col-md-3">
        <label class="form-label fw-semibold">Type</label>
        <select name="movementType" class="form-select">
          <option value="">All Types</option>
          <option value="receipt_supplier" <%= filters.movementType==='receipt_supplier'?'selected':'' %>>Supplier Receipt</option>
          <option value="manual_add" <%= filters.movementType==='manual_add'?'selected':'' %>>Manual Add</option>
          <option value="bill_deduction" <%= filters.movementType==='bill_deduction'?'selected':'' %>>Bill Deduction</option>
          <option value="issuance_salesman" <%= filters.movementType==='issuance_salesman'?'selected':'' %>>Salesman Issuance</option>
          <option value="return_salesman" <%= filters.movementType==='return_salesman'?'selected':'' %>>Salesman Return</option>
          <option value="direct_sale_deduction" <%= filters.movementType==='direct_sale_deduction'?'selected':'' %>>Direct Sale</option>
        </select>
      </div>
      <div class="col-md-3"><button type="submit" class="btn btn-primary"><i class="bi bi-search me-1"></i> Filter</button></div>
    </form>
  </div>
</div>

<div class="card table-card">
  <% if (!data.length) { %>
    <div class="text-center py-5 text-muted">No movements found.</div>
  <% } else { %>
  <table class="table table-sm">
    <thead><tr><th>Date</th><th>Type</th><th>SKU</th><th>Product</th><th>Cartons</th><th>Loose</th><th>Stock After</th><th>By</th></tr></thead>
    <tbody>
      <% data.forEach(r => { %>
      <tr>
        <td class="small"><%= r.movement_date ? new Date(r.movement_date).toLocaleDateString('en-PK') : '' %></td>
        <td><span class="badge bg-secondary-subtle text-secondary small"><%= r.movement_type %></span></td>
        <td><code class="small"><%= r.sku_code %></code></td>
        <td class="small"><%= r.product_name %></td>
        <td><%= r.cartons %></td>
        <td><%= r.loose_units %></td>
        <td class="small"><%= r.stock_after_cartons %>C + <%= r.stock_after_loose %>L</td>
        <td class="small text-muted"><%= r.recorded_by_name || '—' %></td>
      </tr>
      <% }) %>
    </tbody>
  </table>
  <% } %>
</div>

<% if (pagination && pagination.pages > 1) { %>
<nav class="mt-3">
  <ul class="pagination pagination-sm justify-content-center">
    <li class="page-item <%= pagination.page<=1?'disabled':'' %>"><a class="page-link" href="?startDate=<%= filters.startDate||'' %>&endDate=<%= filters.endDate||'' %>&movementType=<%= filters.movementType||'' %>&page=<%= pagination.page-1 %>">Previous</a></li>
    <% for(let p=Math.max(1,pagination.page-2);p<=Math.min(pagination.pages,pagination.page+2);p++){%>
    <li class="page-item <%= p===pagination.page?'active':'' %>"><a class="page-link" href="?startDate=<%= filters.startDate||'' %>&endDate=<%= filters.endDate||'' %>&movementType=<%= filters.movementType||'' %>&page=<%= p %>"><%= p %></a></li>
    <%}%>
    <li class="page-item <%= pagination.page>=pagination.pages?'disabled':'' %>"><a class="page-link" href="?startDate=<%= filters.startDate||'' %>&endDate=<%= filters.endDate||'' %>&movementType=<%= filters.movementType||'' %>&page=<%= pagination.page+1 %>">Next</a></li>
  </ul>
  <div class="text-center small text-muted">Page <%= pagination.page %> of <%= pagination.pages %> (<%= pagination.total %> records)</div>
</nav>
<% } %>
