<div class="page-header">
  <div><h4>Supplier Advance Report</h4><% if (data && data.company) { %><div class="page-sub"><%= data.company.name %></div><% } %></div>
  <div class="d-flex gap-2">
    <% if (data && data.company) { %><a href="/reports/supplier-advance?companyId=<%= data.company.id %>&export=excel" class="btn btn-outline-success btn-sm"><i class="bi bi-file-earmark-excel me-1"></i> Export</a><% } %>
    <a href="/reports" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left me-1"></i> Reports</a>
  </div>
</div>

<% if (typeof noSelection !== 'undefined' && noSelection) { %>
<div class="alert alert-info">
  <i class="bi bi-info-circle me-2"></i>Please select a supplier from the <a href="/reports">Reports page</a> to view the supplier advance report.
</div>
<% } else if (data && data.company) { %>
<div class="card mb-3">
  <div class="card-body d-flex justify-content-between">
    <div class="fw-bold fs-5"><%= data.company.name %></div>
    <div class="text-end"><div class="small text-muted">Current Balance</div><div class="fw-bold fs-4 text-primary">Rs <%= Number(data.current_balance||0).toLocaleString() %></div></div>
  </div>
</div>

<div class="row g-4">
  <div class="col-md-4">
    <div class="card"><div class="card-header fw-semibold">Advances</div>
    <div class="card-body p-0">
      <table class="table table-sm mb-0"><thead><tr><th>Date</th><th>Amount</th><th>Method</th></tr></thead><tbody>
      <% (data.advances||[]).forEach(a => { %><tr><td class="small"><%= a.advance_date %></td><td class="text-success fw-semibold">Rs <%= Number(a.amount).toLocaleString() %></td><td class="small"><%= a.payment_method %></td></tr><% }) %>
      <% if (!data.advances||!data.advances.length) { %><tr><td colspan="3" class="text-center text-muted py-3">No advances found.</td></tr><% } %>
      </tbody></table>
    </div></div>
  </div>
  <div class="col-md-4">
    <div class="card"><div class="card-header fw-semibold">Stock Receipts</div>
    <div class="card-body p-0">
      <table class="table table-sm mb-0"><thead><tr><th>Date</th><th>Value</th><th>Items</th></tr></thead><tbody>
      <% (data.receipts||[]).forEach(r => { %><tr><td class="small"><%= r.receipt_date %></td><td class="text-danger fw-semibold">Rs <%= Number(r.total_value).toLocaleString() %></td><td><%= r.item_count %></td></tr><% }) %>
      <% if (!data.receipts||!data.receipts.length) { %><tr><td colspan="3" class="text-center text-muted py-3">No receipts found.</td></tr><% } %>
      </tbody></table>
    </div></div>
  </div>
  <div class="col-md-4">
    <div class="card"><div class="card-header fw-semibold">Claims</div>
    <div class="card-body p-0">
      <table class="table table-sm mb-0"><thead><tr><th>Date</th><th>Value</th><th>Status</th></tr></thead><tbody>
      <% (data.claims||[]).forEach(c => { %><tr><td class="small"><%= c.claim_date %></td><td class="fw-semibold">Rs <%= Number(c.claim_value).toLocaleString() %></td><td><span class="badge <%= c.status==='cleared'?'bg-success-subtle text-success':'bg-warning-subtle text-warning' %> small"><%= c.status %></span></td></tr><% }) %>
      <% if (!data.claims||!data.claims.length) { %><tr><td colspan="3" class="text-center text-muted py-3">No claims found.</td></tr><% } %>
      </tbody></table>
    </div></div>
  </div>
</div>

<% 
const queryString = new URLSearchParams({ companyId: data.company.id }).toString();
%>
<%- include('../layout/pagination', { pagination, queryString }) %>

<% } %>
