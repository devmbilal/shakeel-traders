<div class="page-header">
  <div><h4>Claims Report</h4><% if (data && data.company) { %><div class="page-sub"><%= data.company.name %></div><% } %></div>
  <div class="d-flex gap-2">
    <% if (data && data.company) { %><a href="/reports/claims?companyId=<%= data.company.id %>&export=excel" class="btn btn-outline-success btn-sm"><i class="bi bi-file-earmark-excel me-1"></i> Export</a><% } %>
    <a href="/reports" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left me-1"></i> Reports</a>
  </div>
</div>

<% if (noSelection) { %>
<div class="alert alert-info">
  <i class="bi bi-info-circle me-2"></i>Please select a supplier from the <a href="/reports">Reports page</a> to view the claims report.
</div>
<% } else { %>

<div class="card table-card">
  <% if (!data.claims||!data.claims.length) { %>
    <div class="text-center py-5 text-muted">No claims found.</div>
  <% } else { %>
  <table class="table">
    <thead><tr><th>Date</th><th>Value</th><th>Reason</th><th>Products</th><th>Status</th><th>Cleared By</th></tr></thead>
    <tbody>
      <% data.claims.forEach(c => { %>
      <tr>
        <td class="small"><%= c.claim_date %></td>
        <td class="fw-semibold">Rs <%= Number(c.claim_value).toLocaleString() %></td>
        <td class="small"><%= c.reason %></td>
        <td class="small text-muted"><%= c.products || '—' %></td>
        <td><span class="badge <%= c.status==='cleared'?'bg-success-subtle text-success':'bg-warning-subtle text-warning' %> small"><%= c.status %></span></td>
        <td class="small"><%= c.cleared_by_name || '—' %></td>
      </tr>
      <% }) %>
    </tbody>
  </table>
  <% } %>
</div>

<% if (data && data.company) { 
const queryString = new URLSearchParams({ companyId: data.company.id }).toString();
%>
<%- include('../layout/pagination', { pagination, queryString }) %>
<% } %>

<% } %>
