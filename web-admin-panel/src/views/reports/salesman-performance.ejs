<div class="page-header">
  <div><h4>Salesman Performance</h4></div>
  <div class="d-flex gap-2">
    <a href="/reports/salesman-performance?startDate=<%= filters.startDate||'' %>&endDate=<%= filters.endDate||'' %>&export=excel" class="btn btn-outline-success btn-sm"><i class="bi bi-file-earmark-excel me-1"></i> Export</a>
    <a href="/reports" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left me-1"></i> Reports</a>
  </div>
</div>

<div class="card mb-4">
  <div class="card-body">
    <form method="GET" action="/reports/salesman-performance" class="row g-3 align-items-end">
      <div class="col-md-3"><label class="form-label fw-semibold">From</label><input type="date" name="startDate" class="form-control" value="<%= filters.startDate||'' %>"></div>
      <div class="col-md-3"><label class="form-label fw-semibold">To</label><input type="date" name="endDate" class="form-control" value="<%= filters.endDate||'' %>"></div>
      <div class="col-md-3"><button type="submit" class="btn btn-primary"><i class="bi bi-search me-1"></i> Filter</button></div>
    </form>
  </div>
</div>

<div class="card table-card">
  <% if (!data.length) { %>
    <div class="text-center py-5 text-muted">No data found.</div>
  <% } else { %>
  <table class="table">
    <thead><tr><th>Salesman</th><th>Issuances</th><th>Issued</th><th>Returned</th><th>Sale Value</th></tr></thead>
    <tbody>
      <% data.forEach(r => { %>
      <tr>
        <td><div class="fw-semibold"><%= r.full_name %></div><div class="small text-muted"><%= r.username %></div></td>
        <td><%= r.issuances_count %></td>
        <td><%= r.total_issued_cartons %>C + <%= r.total_issued_loose %>L</td>
        <td><%= r.total_returned_cartons %>C + <%= r.total_returned_loose %>L</td>
        <td class="text-success fw-semibold">Rs <%= Number(r.total_sale_value||0).toLocaleString() %></td>
      </tr>
      <% }) %>
    </tbody>
  </table>
  <% } %>
</div>

<% 
const queryString = new URLSearchParams({ startDate: filters.startDate||'', endDate: filters.endDate||'' }).toString();
%>
<%- include('../layout/pagination', { pagination, queryString }) %>
