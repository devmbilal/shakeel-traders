<div class="page-header">
  <div><h4>Shop Ledger Report</h4><% if (data && data.shop) { %><div class="page-sub"><%= data.shop.name %></div><% } %></div>
  <div class="d-flex gap-2">
    <% if (data && data.shop) { %><a href="/reports/shop-ledger?shopId=<%= data.shop.id %>&export=excel" class="btn btn-outline-success btn-sm"><i class="bi bi-file-earmark-excel me-1"></i> Export</a><% } %>
    <a href="/reports" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left me-1"></i> Reports</a>
  </div>
</div>

<% if (noSelection) { %>
<div class="alert alert-info">
  <i class="bi bi-info-circle me-2"></i>Please select a shop from the <a href="/reports">Reports page</a> to view the shop ledger.
</div>
<% } else if (data && data.shop) { %>
<div class="card mb-3">
  <div class="card-body d-flex justify-content-between align-items-center">
    <div>
      <div class="fw-bold fs-5"><%= data.shop.name %></div>
      <div class="small text-muted"><%= data.shop.route_name %></div>
    </div>
    <div class="text-end">
      <div class="small text-muted">Current Balance</div>
      <div class="fw-bold fs-4 <%= data.current_balance < 0 ? 'text-success' : data.current_balance > 0 ? 'text-danger' : 'text-muted' %>">
        Rs <%= Math.abs(data.current_balance).toLocaleString('en-PK',{minimumFractionDigits:2}) %>
        <%= data.current_balance < 0 ? '(Credit)' : data.current_balance > 0 ? '(Outstanding)' : '' %>
      </div>
    </div>
  </div>
</div>

<div class="card table-card">
  <% if (!data.entries.length) { %>
    <div class="text-center py-5 text-muted">No ledger entries found.</div>
  <% } else { %>
  <table class="table table-sm">
    <thead><tr><th>Date</th><th>Type</th><th>Note</th><th class="text-end">Debit</th><th class="text-end">Credit</th><th class="text-end">Balance</th></tr></thead>
    <tbody>
      <% data.entries.forEach(e => { %>
      <tr>
        <td class="small"><%= e.entry_date ? new Date(e.entry_date).toLocaleDateString('en-PK') : '' %></td>
        <td><span class="badge bg-secondary-subtle text-secondary small"><%= e.entry_type %></span></td>
        <td class="small text-muted"><%= e.note || '—' %></td>
        <td class="text-end small <%= parseFloat(e.debit)>0?'text-danger':'' %>"><%= parseFloat(e.debit)>0 ? 'Rs '+Number(e.debit).toLocaleString() : '—' %></td>
        <td class="text-end small <%= parseFloat(e.credit)>0?'text-success':'' %>"><%= parseFloat(e.credit)>0 ? 'Rs '+Number(e.credit).toLocaleString() : '—' %></td>
        <td class="text-end small fw-semibold <%= parseFloat(e.balance_after)<0?'text-success':parseFloat(e.balance_after)>0?'text-danger':'text-muted' %>">Rs <%= Number(e.balance_after).toLocaleString() %></td>
      </tr>
      <% }) %>
    </tbody>
  </table>
  <% } %>
</div>

<% 
const queryString = new URLSearchParams({ shopId: data.shop.id }).toString();
%>
<%- include('../layout/pagination', { pagination, queryString }) %>

<% } %>
