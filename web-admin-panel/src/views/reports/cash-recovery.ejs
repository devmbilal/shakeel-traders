<div class="page-header">
  <div><h4>Cash Recovery Report</h4></div>
  <div class="d-flex gap-2">
    <a href="/reports/cash-recovery?startDate=<%= filters.startDate||'' %>&endDate=<%= filters.endDate||'' %>&export=excel" class="btn btn-outline-success btn-sm"><i class="bi bi-file-earmark-excel me-1"></i> Export</a>
    <a href="/reports" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left me-1"></i> Reports</a>
  </div>
</div>

<div class="card mb-4">
  <div class="card-body">
    <form method="GET" action="/reports/cash-recovery" class="row g-3 align-items-end">
      <div class="col-md-3"><label class="form-label fw-semibold">From</label><input type="date" name="startDate" class="form-control" value="<%= filters.startDate||'' %>"></div>
      <div class="col-md-3"><label class="form-label fw-semibold">To</label><input type="date" name="endDate" class="form-control" value="<%= filters.endDate||'' %>"></div>
      <div class="col-md-3"><button type="submit" class="btn btn-primary"><i class="bi bi-search me-1"></i> Filter</button></div>
    </form>
  </div>
</div>

<div class="card table-card">
  <% if (!data.length) { %>
    <div class="text-center py-5 text-muted">No recovery data found.</div>
  <% } else { %>
  <table class="table table-sm">
    <thead><tr><th>Date</th><th>Bill #</th><th>Shop</th><th>Booker</th><th class="text-end">Outstanding</th><th class="text-end">Collected</th><th>Method</th><th>Status</th></tr></thead>
    <tbody>
      <% data.forEach(r => { %>
      <tr>
        <td class="small"><%= r.assigned_date %></td>
        <td><code class="small"><%= r.bill_number %></code></td>
        <td class="small"><%= r.shop_name %></td>
        <td class="small"><%= r.booker_name %></td>
        <td class="text-end text-warning fw-semibold">Rs <%= Number(r.outstanding_amount||0).toLocaleString() %></td>
        <td class="text-end text-success fw-semibold"><%= r.amount_collected ? 'Rs '+Number(r.amount_collected).toLocaleString() : '—' %></td>
        <td class="small"><%= r.payment_method || '—' %></td>
        <td><span class="badge <%= r.status==='fully_recovered'?'bg-success-subtle text-success':r.status==='partially_recovered'?'bg-warning-subtle text-warning':'bg-secondary-subtle text-secondary' %> small"><%= r.status %></span></td>
      </tr>
      <% }) %>
    </tbody>
  </table>
  <% } %>
</div>

<% 
const queryString = new URLSearchParams({ startDate: filters.startDate||'', endDate: filters.endDate||'' }).toString();
%>
<%- include('../layout/pagination', { pagination, queryString }) %>
