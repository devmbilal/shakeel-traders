<div class="page-header">
  <div>
    <h4><%= isEdit ? 'Edit User' : 'Add User' %></h4>
    <div class="page-sub"><%= isEdit ? 'Update user details' : 'Create a new ' + (role === 'salesman' ? 'salesman' : 'order booker') %></div>
  </div>
  <a href="/users?tab=<%= role === 'salesman' ? 'salesmen' : 'order_bookers' %>" class="btn btn-outline-secondary btn-sm">
    <i class="bi bi-arrow-left me-1"></i> Back
  </a>
</div>

<div class="row justify-content-center">
  <div class="col-lg-6">
    <div class="card">
      <div class="card-header d-flex align-items-center gap-2">
        <div style="width:32px;height:32px;background:#DBEAFE;border-radius:8px;display:flex;align-items:center;justify-content:center;">
          <i class="bi bi-person-<%= isEdit ? 'gear' : 'plus' %>" style="color:var(--secondary);"></i>
        </div>
        <span style="font-family:'Manrope',sans-serif;font-weight:700;"><%= isEdit ? 'Edit User' : 'New User' %></span>
      </div>
      <div class="card-body">
        <form method="POST" action="<%= isEdit ? '/users/' + user.id : '/users' %>">
          <% if (!isEdit) { %><input type="hidden" name="role" value="<%= role %>"><% } %>

          <div class="mb-3">
            <label class="form-label">Role</label>
            <div class="form-control" style="background:var(--bg);color:var(--text-secondary);">
              <i class="bi bi-<%= role === 'salesman' ? 'truck' : 'person-walking' %> me-2"></i>
              <%= role === 'order_booker' ? 'Order Booker' : 'Salesman' %>
            </div>
          </div>

          <div class="mb-3">
            <label class="form-label">Full Name <span style="color:#EF4444;">*</span></label>
            <input type="text" name="full_name" class="form-control" required value="<%= isEdit ? user.full_name : '' %>" placeholder="Enter full name">
          </div>

          <div class="mb-3">
            <label class="form-label">Username <span style="color:#EF4444;">*</span></label>
            <div class="input-group">
              <span class="input-group-text"><i class="bi bi-at"></i></span>
              <input type="text" name="username" class="form-control" required value="<%= isEdit ? user.username : '' %>" autocomplete="off" placeholder="Login username">
            </div>
          </div>

          <div class="mb-3">
            <label class="form-label">Password <% if (!isEdit) { %><span style="color:#EF4444;">*</span><% } %></label>
            <div class="input-group">
              <span class="input-group-text"><i class="bi bi-lock"></i></span>
              <input type="password" name="password" class="form-control" <%= !isEdit ? 'required' : '' %> autocomplete="new-password" placeholder="<%= isEdit ? 'Leave blank to keep current password' : 'Set a strong password' %>">
            </div>
            <% if (isEdit) { %><div style="font-size:0.75rem;color:var(--text-muted);margin-top:4px;">Leave blank to keep the current password.</div><% } %>
          </div>

          <div class="mb-3">
            <label class="form-label">Contact Number</label>
            <div class="input-group">
              <span class="input-group-text"><i class="bi bi-telephone"></i></span>
              <input type="text" name="contact" class="form-control" value="<%= isEdit ? (user.contact || '') : '' %>" placeholder="03xx-xxxxxxx">
            </div>
          </div>

          <div class="divider"></div>
          <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary">
              <i class="bi bi-check-lg me-1"></i> <%= isEdit ? 'Save Changes' : 'Create User' %>
            </button>
            <a href="/users?tab=<%= role === 'salesman' ? 'salesmen' : 'order_bookers' %>" class="btn btn-outline-secondary">Cancel</a>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>
