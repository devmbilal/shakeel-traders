<div class="page-header">
  <div>
    <h4>Expenses Management</h4>
    <div class="page-sub">Record and track business expenses</div>
  </div>
  <button class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#addExpenseModal">
    <i class="bi bi-plus-lg me-1"></i> Add Expense
  </button>
</div>

<!-- Filters -->
<div class="card mb-3">
  <div class="card-body">
    <form method="GET" action="/expenses" class="row g-3">
      <div class="col-md-3">
        <label class="form-label">Expense Type</label>
        <select name="type" class="form-select form-select-sm">
          <option value="">All Types</option>
          <% expenseTypes.forEach(type => { %>
            <option value="<%= type %>" <%= filters.type === type ? 'selected' : '' %>><%= type %></option>
          <% }) %>
        </select>
      </div>
      <div class="col-md-2">
        <label class="form-label">From Date</label>
        <input type="date" name="dateFrom" class="form-control form-control-sm" value="<%= filters.dateFrom || '' %>">
      </div>
      <div class="col-md-2">
        <label class="form-label">To Date</label>
        <input type="date" name="dateTo" class="form-control form-control-sm" value="<%= filters.dateTo || '' %>">
      </div>
      <div class="col-md-3">
        <label class="form-label">Related User</label>
        <select name="userId" class="form-select form-select-sm">
          <option value="">All Users</option>
          <% users.forEach(u => { %>
            <option value="<%= u.id %>" <%= filters.userId == u.id ? 'selected' : '' %>><%= u.full_name %></option>
          <% }) %>
        </select>
      </div>
      <div class="col-md-2 d-flex align-items-end">
        <button type="submit" class="btn btn-secondary btn-sm me-2">Filter</button>
        <a href="/expenses" class="btn btn-outline-secondary btn-sm">Clear</a>
      </div>
    </form>
  </div>
</div>

<!-- Total Summary -->
<% if (expenses.length > 0) { %>
<div class="alert alert-info mb-3">
  <strong>Total Expenses:</strong> Rs <%= total.toFixed(2) %>
  <% if (filters.dateFrom || filters.dateTo) { %>
    <span class="ms-2">(Filtered)</span>
  <% } %>
</div>
<% } %>

<% if (pagination && pagination.total > 0) { %>
  <p class="text-muted small mb-2"><%= pagination.total %> records</p>
<% } %>

<!-- Expenses Table -->
<div class="card table-card">
  <% if (expenses.length === 0) { %>
    <div style="text-align:center;padding:48px;color:var(--text-muted);">
      No expenses found. <% if (filters.type || filters.dateFrom || filters.dateTo || filters.userId) { %>Try adjusting your filters.<% } %>
    </div>
  <% } else { %>
  <table class="table">
    <thead>
      <tr>
        <th>Date</th>
        <th>Type</th>
        <th>Amount</th>
        <th>Related User</th>
        <th>Note</th>
      </tr>
    </thead>
    <tbody>
      <% expenses.forEach(e => { %>
      <tr>
        <td><%= new Date(e.expense_date).toLocaleDateString('en-GB') %></td>
        <td><span class="badge bg-secondary"><%= e.expense_type %></span></td>
        <td>
          <span style="font-family:'Manrope',sans-serif;font-weight:700;color:#EF4444;">
            Rs <%= Number(e.amount).toFixed(2) %>
          </span>
        </td>
        <td><%= e.related_user_name || '—' %></td>
        <td><%= e.note || '—' %></td>
      </tr>
      <% }) %>
    </tbody>
  </table>
  <% } %>
</div>

<%- include('../layout/pagination', {pagination, queryString}) %>

<!-- Add Expense Modal -->
<div class="modal fade" id="addExpenseModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h6 class="modal-title">Add New Expense</h6>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <form method="POST" action="/expenses">
        <div class="modal-body">
          <div class="mb-3">
            <label class="form-label">Expense Type <span style="color:#EF4444;">*</span></label>
            <select name="expense_type" class="form-select" required>
              <option value="">Select Type</option>
              <% expenseTypes.forEach(type => { %>
                <option value="<%= type %>"><%= type %></option>
              <% }) %>
            </select>
          </div>
          <div class="mb-3">
            <label class="form-label">Amount (Rs) <span style="color:#EF4444;">*</span></label>
            <input type="number" name="amount" class="form-control" step="0.01" min="0" required>
          </div>
          <div class="mb-3">
            <label class="form-label">Date <span style="color:#EF4444;">*</span></label>
            <input type="date" name="expense_date" class="form-control" value="<%= new Date().toISOString().slice(0,10) %>" required>
          </div>
          <div class="mb-3">
            <label class="form-label">Related User (Optional)</label>
            <select name="related_user_id" class="form-select">
              <option value="">None</option>
              <% users.forEach(u => { %>
                <option value="<%= u.id %>"><%= u.full_name %> (<%= u.role %>)</option>
              <% }) %>
            </select>
          </div>
          <div class="mb-3">
            <label class="form-label">Note</label>
            <textarea name="note" class="form-control" rows="3"></textarea>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-outline-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
          <button type="submit" class="btn btn-primary btn-sm">Record Expense</button>
        </div>
      </form>
    </div>
  </div>
</div>
